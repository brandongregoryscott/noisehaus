{
    "$schema": "https://turbo.build/schema.json",
    "globalDependencies": ["**/.env.*local"],
    "globalEnv": ["VITE_API_URL"],
    "tasks": {
        "build": {
            "dependsOn": ["^build"],
            "outputs": ["dist/**"]
        },
        "lint": {},
        "lint:fix": {},
        "test": {},
        "test:watch": { "cache": false, "persistent": true },
        "dev": {
            "cache": false,
            "persistent": true
        }
    }
}
